# Turso booking database. Keep both values server-only; do not use NEXT_PUBLIC_.
TURSO_DATABASE_URL=libsql://your-database-your-organisation.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# One shared Studio GQ crew portal identity. These values stay server-only.
CREW_PORTAL_EMAIL=bookings@studiogq.co.za
CREW_PORTAL_PASSWORD=choose-a-long-shared-crew-password
CREW_SESSION_SECRET=generate-a-random-secret-of-at-least-32-characters

# Internal booking notification. Configure Resend and verify the sending domain
# before setting BOOKING_FROM_EMAIL in Vercel.
RESEND_API_KEY=re_your-resend-key
BOOKING_FROM_EMAIL=Studio GQ <booking@studiogq.co.za>
BOOKING_NOTIFICATION_EMAIL=booking@studiogq.co.za
