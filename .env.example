# Public Supabase connection values. The URL and publishable key may be used in
# browser code, but never put a service-role key in a NEXT_PUBLIC_ variable.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-only credentials. Never expose the service-role key through a
# NEXT_PUBLIC_ variable or commit real credentials to source control.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used only by the crew login route. The publishable key is safe to send to
# Supabase, but all values remain server-side in this app. SUPABASE_ANON_KEY is
# also accepted for older Supabase projects.
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
CREW_PORTAL_EMAIL=bookings@studiogq.co.za
